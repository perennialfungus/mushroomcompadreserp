{
  "name": "@mushroom-compadres/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    }
  },
  "scripts": {
    "build": "node ../../node_modules/typescript/lib/tsc.js -p tsconfig.build.json",
    "db:generate": "node ../../node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "node ../../node_modules/tsx/dist/cli.mjs src/migrate.ts",
    "db:seed": "node ../../node_modules/tsx/dist/cli.mjs src/seed.ts",
    "lint": "node ../../node_modules/eslint/bin/eslint.js .",
    "test": "node ../../node_modules/vitest/vitest.mjs run",
    "typecheck": "node ../../node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "@mushroom-compadres/domain": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "pg": "^8.16.0"
  },
  "devDependencies": {
    "@types/pg": "^8.15.0",
    "drizzle-kit": "^0.31.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
